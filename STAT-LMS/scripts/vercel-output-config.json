{
    "version": 3,
    "routes": [
        {
            "src": "/assets/runtime-worker-.*\\.js",
            "headers": {
                "Service-Worker-Allowed": "/",
                "Cache-Control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/assets/.*\\.wasm",
            "headers": {
                "Content-Type": "application/wasm",
                "Cache-Control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/(?:assets|runtime)/.*",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/demo-runtime-manifest\\.json",
            "headers": { "Cache-Control": "no-store" },
            "continue": true
        },
        {
            "src": "/pdfs/.*",
            "headers": { "Cache-Control": "no-store" },
            "continue": true
        },
        { "handle": "filesystem" },
        { "src": "/.*", "dest": "/index.html" }
    ]
}
