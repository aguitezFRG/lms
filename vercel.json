{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "cd STAT-LMS && composer demo:build",
    "outputDirectory": "STAT-LMS/client/dist",
    "headers": [
        {
            "source": "/assets/runtime-worker-(.*)\\.js",
            "headers": [
                { "key": "Service-Worker-Allowed", "value": "/" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/runtime/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/demo-runtime-manifest.json",
            "headers": [
                { "key": "Cache-Control", "value": "no-store" }
            ]
        },
        {
            "source": "/pdfs/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-store" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/((?!assets/|runtime/|build/|css/|fonts/|images/|js/|pdfs/|demo-runtime-manifest\\.json|laravel-demo-v1\\.zip|_headers|_redirects).*)", "destination": "/index.html" }
    ]
}
